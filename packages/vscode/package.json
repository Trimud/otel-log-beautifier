{
  "name": "otel-log-beautifier",
  "displayName": "OTel Log Beautifier",
  "description": "Beautifies OpenTelemetry JSON structured logs in the VS Code terminal",
  "version": "0.2.0",
  "publisher": "trimud",
  "license": "MIT",
  "icon": "icon.png",
  "homepage": "https://github.com/Trimud/otel-log-beautifier#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Trimud/otel-log-beautifier"
  },
  "bugs": {
    "url": "https://github.com/Trimud/otel-log-beautifier/issues"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "logs",
    "logging",
    "json",
    "terminal",
    "beautifier",
    "pino",
    "winston",
    "bunyan",
    "structured-logs",
    "ndjson"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Visualization"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "terminal": {
      "profiles": [
        {
          "id": "otelLogBeautifier.terminalProfile",
          "title": "OTel Beautified"
        }
      ]
    },
    "commands": [
      {
        "command": "otelLogBeautifier.openTerminal",
        "title": "OTel: Open Beautified Terminal"
      },
      {
        "command": "otelLogBeautifier.toggleBeautify",
        "title": "OTel: Toggle Beautify"
      },
      {
        "command": "otelLogBeautifier.filterError",
        "title": "OTel: Show Only ERROR"
      },
      {
        "command": "otelLogBeautifier.filterWarn",
        "title": "OTel: Show Only WARN+"
      },
      {
        "command": "otelLogBeautifier.filterAll",
        "title": "OTel: Show All Levels"
      },
      {
        "command": "otelLogBeautifier.setAsDefault",
        "title": "OTel: Set as Default Terminal"
      },
      {
        "command": "otelLogBeautifier.removeDefault",
        "title": "OTel: Restore Default Terminal"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@otel-log-beautifier/core": "*",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
